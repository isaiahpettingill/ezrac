import agon.mos

pub const LF: u8 = 10
pub const CR: u8 = 13
pub const CLEAR: u8 = 12

pub fn write(ch: u8) {
    mos.putc(ch)
}

pub fn print(text: ptr<u8>) {
    mos.puts(text)
}

pub fn newline() {
    write(CR)
    write(LF)
}

pub fn clear() {
    write(CLEAR)
}

pub fn exit_emulator(code: u8) {
    mos.exit(code)
}
