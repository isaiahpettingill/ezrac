import agon.vdp

fn main() {
    vdp.mode_8()
    vdp.clear_graphics_color(vdp.COLOR_BLACK)
    let y: u16 = 0
    while y < 120 {
        let x: u16 = 0
        while x < 160 {
            let value: u8 = cast<u8>((x * x + y * y) >> 10) & 15
            vdp.draw_color(value)
            vdp.point(x << 1, y << 1)
            x = x + 1
        }
        y = y + 1
    }
}
