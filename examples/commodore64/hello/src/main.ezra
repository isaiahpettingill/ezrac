import c64.vic
import c64.cia
import c64.memory
import c64.text

fn main() {
    memory.map_roms_and_io()
    vic.border(vic.BLUE)
    vic.background(vic.LIGHT_BLUE)
    vic.clear(text.CHAR_SPACE, vic.WHITE)
    text.put_ascii(13, 10, "HELLO, WORLD!")
    text.put_ascii(10, 14, "PRESS Q TO EXIT")

    while !cia.key_pressed(cia.KEY_Q) {}
}
