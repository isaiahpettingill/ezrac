import gb.video
import gb.sprites

// A simple 8x8 smile sprite in native Game Boy 2bpp format.
embed smile_sprite: bytes = bytes [
    0x3C, 0x3C, 0x42, 0x42, 0xA5, 0xA5, 0x81, 0x81,
    0xA5, 0xA5, 0x99, 0x99, 0x42, 0x42, 0x3C, 0x3C
]

fn main() {
    video.begin_update()
    sprites.clear_background_tile()
    sprites.upload_tile1(&smile_sprite)
    video.clear_background()
    sprites.show_centered_tile1()
    video.enable_background_and_sprites()
}
