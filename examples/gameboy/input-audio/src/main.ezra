import gb.video
import gb.input
import gb.audio

// 32 four-bit samples packed two per byte. Asset placement comes from Ezra.toml.
embed wave: bytes = bytes [
    0x01, 0x23, 0x45, 0x67, 0x89, 0xAB, 0xCD, 0xEF,
    0xFE, 0xDC, 0xBA, 0x98, 0x76, 0x54, 0x32, 0x10
]

fn main() {
    video.begin_update()
    video.clear_background()
    video.enable_background()
    audio.enable()
    audio.load_wave(&wave)
    input.wait_for_a()
    audio.play_beep()
    audio.play_wave()
}
